# ─────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── App Settings ───────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────
# SQLite (default, no setup needed)
DB_PATH=sqlite+aiosqlite:///./resume_analyzer.db

# PostgreSQL (production)
# DB_PATH=postgresql+asyncpg://user:password@localhost:5432/resume_analyzer

# ── Kaggle API ─────────────────────────────────────────────────
# Get from: https://www.kaggle.com/settings/account → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── OpenAI (Optional — for GPT-powered suggestions) ────────────
# If not set, falls back to rule-based suggestions (works without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
USE_LLM=false

# ── NLP Model Selection ────────────────────────────────────────
SBERT_MODEL=all-MiniLM-L6-v2
BERT_MODEL=bert-base-uncased
SPACY_MODEL=en_core_web_sm

# ── Score Weights (must sum to 1.0) ────────────────────────────
TFIDF_WEIGHT=0.25
SBERT_WEIGHT=0.55
BERT_WEIGHT=0.20
